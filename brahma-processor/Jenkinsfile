pipeline {
    agent any

    environment {
        APP_NAME = 'brahma-processor'
        K8S_NAMESPACE = 'default'
        IMAGE_TAG = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Maven Build') {
            steps {
                sh 'mvn clean install -DskipTests -Dquarkus.package.jar.type=uber-jar'
            }
        }

        stage('Docker Build & Load') {
            steps {
                script {
                    def image = "${APP_NAME}:${IMAGE_TAG}"
                    dir('brahma-processor') {
                        sh "eval \$(minikube docker-env) && docker build -t ${image} ."
                    }
                }
            }
        }

        stage('Deploy to K8s') {
            steps {
                script {
                    def image = "${APP_NAME}:${IMAGE_TAG}"
                    sh """
                        kubectl apply -f k8s/brahma-processor.yaml -n ${K8S_NAMESPACE}
                        kubectl set image deployment/${APP_NAME} ${APP_NAME}=${image} -n ${K8S_NAMESPACE}
                        kubectl rollout status deployment/${APP_NAME} -n ${K8S_NAMESPACE} --timeout=120s
                    """
                }
            }
        }

        stage('Verify') {
            steps {
                script {
                    echo "Waiting for ${APP_NAME} pod to be ready..."
                    // Ждем, пока под процессора не станет Ready
                    sh """
                        for i in 1 2 3 4 5; do
                            echo "Attempt \$i/5..."
                            if kubectl get pods -n ${K8S_NAMESPACE} -l app=${APP_NAME} --field-selector=status.phase=Running | grep -q '1/1'; then
                                echo "${APP_NAME} is Running and Ready!"
                                exit 0
                            fi
                            sleep 10
                        done
                        echo "${APP_NAME} did not become ready after 5 attempts"
                        exit 1
                    """
                }
            }
        }
    }

    post {
        success {
            echo "✅ ${APP_NAME} версия ${IMAGE_TAG} успешно задеплоен"
        }
        failure {
            echo "❌ Деплой ${APP_NAME} провален. Проверь логи."
        }
    }
}