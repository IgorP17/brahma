pipeline {
    agent any

    environment {
        APP_NAME = 'brahma-webui'
        K8S_NAMESPACE = 'default'
        // Используем уникальный тег на основе времени
        IMAGE_TAG = "${System.currentTimeMillis()}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Maven Build') {
            steps {
                sh 'mvn clean install -DskipTests'
                dir('brahma-webui') {
                    // ВАЖНО: добавляем clean!
                    sh 'mvn clean package -Dquarkus.package.jar.type=uber-jar -DskipTests'
                }
            }
        }

        stage('Docker Build & Load') {
            steps {
                script {
                    def image = "${APP_NAME}:${IMAGE_TAG}"
                    dir('brahma-webui') {
                        sh "docker build -t ${image} ."
                        sh "minikube image load ${image}"
                    }
                }
            }
        }

        stage('Deploy to K8s') {
            steps {
                script {
                    def image = "${APP_NAME}:${IMAGE_TAG}"
                    sh """
                        kubectl set image deployment/${APP_NAME} \
                            ${APP_NAME}=${image} \
                            -n ${K8S_NAMESPACE}
                        kubectl rollout status deployment/${APP_NAME} -n ${K8S_NAMESPACE} --timeout=120s
                    """
                }
            }
        }

        stage('Verify') {
            steps {
                script {
                    // Ждём, пока приложение реально запустится
                    echo "⏳ Ожидаем старта приложения..."
                    sleep 30

                    // Пробуем несколько раз
                    sh '''
                        for i in 1 2 3 4 5; do
                            echo "Попытка $i/5..."
                            if curl -sf http://minikube:30082 > /dev/null 2>&1; then
                                echo "✅ Приложение отвечает!"
                                exit 0
                            fi
                            sleep 10
                        done
                        echo "❌ Приложение не отвечает после 5 попыток"
                        exit 1
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "✅ ${APP_NAME} успешно задеплоен"
        }
        failure {
            echo "❌ Деплой ${APP_NAME} провален. Проверь логи."
        }
    }
}