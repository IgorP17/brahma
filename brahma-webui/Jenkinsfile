pipeline {
    agent any

    environment {
        APP_NAME = 'brahma-webui'
        K8S_NAMESPACE = 'default'
        IMAGE_TAG = "${env.BUILD_ID}-${env.GIT_COMMIT?.take(7) ?: 'latest'}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Maven Build') {
            steps {
                // Собираем весь проект из корня (включая parent POM)
                sh 'mvn clean install -DskipTests'

                // Пересобираем webui с uber-jar
                dir('brahma-webui') {
                    sh 'mvn package -Dquarkus.package.jar.type=uber-jar -DskipTests'
                }
            }
        }

        stage('Docker Build & Load') {
            steps {
                script {
                    def image = "${APP_NAME}:${IMAGE_TAG}"
                    dir('brahma-webui') {
                        sh "docker build -t ${image} ."
                        sh "minikube image load ${image}"
                    }
                }
            }
        }

        stage('Deploy to K8s') {
            steps {
                script {
                    def image = "${APP_NAME}:${IMAGE_TAG}"
                    sh """
                        kubectl set image deployment/${APP_NAME} \
                            ${APP_NAME}=${image} \
                            -n ${K8S_NAMESPACE}
                        kubectl rollout status deployment/${APP_NAME} -n ${K8S_NAMESPACE} --timeout=120s
                    """
                }
            }
        }

        stage('Verify') {
            steps {
                sh 'curl -sf http://minikube:30082 || exit 1'
            }
        }
    }

    post {
        success {
            echo "✅ ${APP_NAME} успешно задеплоен с тегом ${IMAGE_TAG}"
        }
        failure {
            echo "❌ Деплой ${APP_NAME} провален. Проверь логи."
        }
    }
}