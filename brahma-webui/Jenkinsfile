pipeline {
    agent any

    environment {
        APP_NAME = 'brahma-webui'
        K8S_NAMESPACE = 'default'
        IMAGE_TAG = 'latest'  // ← Всегда latest
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Maven Build') {
            steps {
                // Собираем всё проект сразу с нужным флагом для uber-jar.
                // Это быстрее, чем собирать дважды.
                // Флаг применится к Quarkus модулям.
                sh 'mvn clean install -DskipTests -Dquarkus.package.jar.type=uber-jar'
            }
        }

        stage('Docker Build & Load') {
            steps {
                script {
                    def image = "${APP_NAME}:${IMAGE_TAG}"
                    dir('brahma-webui') {
                        sh "docker build -t ${image} ."
                        sh "minikube image load ${image}"
                    }
                }
            }
        }

        stage('Deploy to K8s') {
            steps {
                script {
                    sh """
                        # 1. Применяем манифесты
                        kubectl apply -f k8s/brahma-webui.yaml -n ${K8S_NAMESPACE}

                        # 2. Делаем рестарт. Это ключевое действие для тега latest.
                        # Без этого K8s не подтянет новый образ, если тег не изменился.
                        kubectl rollout restart deployment/${APP_NAME} -n ${K8S_NAMESPACE}

                        # 3. Ждем завершения обновления
                        kubectl rollout status deployment/${APP_NAME} -n ${K8S_NAMESPACE} --timeout=120s
                    """
                }
            }
        }

        stage('Verify') {
            steps {
                script {
                    def minikubeIp = sh(script: 'minikube ip', returnStdout: true).trim()

                    echo "Waiting for app at http://${minikubeIp}:30082..."

                    sh '''
                        for i in 1 2 3 4 5; do
                            echo "Attempt $i/5..."
                            if curl -sf http://''' + minikubeIp + ''':30082 > /dev/null 2>&1; then
                                echo "App is responding!"
                                exit 0
                            fi
                            sleep 10
                        done
                        echo "App did not respond after 5 attempts"
                        exit 1
                    '''
                }
            }
        }

    post {
        success {
            echo "✅ ${APP_NAME} успешно задеплоен"
        }
        failure {
            echo "❌ Деплой ${APP_NAME} провален. Проверь логи."
        }
    }
}